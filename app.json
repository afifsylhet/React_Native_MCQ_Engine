{
  "expo": {
    "name": "BD Nursing Preparation",
    "slug": "bd_nursing_preparation",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
